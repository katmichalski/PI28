# Copy to .env and restart the server
OCRMYPDF_CMDLINE=py -m ocrmypdf

# PDF type detection (used to avoid running OCRmyPDF when the PDF is already searchable)
# PDF_TYPE_SAMPLE_PAGES=3
# PDF_TYPE_MIN_CHARS_PER_PAGE=20

# OCRmyPDF tuning
# OCRMYPDF_CLEAN_FINAL=1
# OCRMYPDF_REMOVE_BACKGROUND=0
# OCRMYPDF_JOBS=2

# Image OCR tuning (scanned PDFs)
# Default is now 0.40 (top 40% of the page) to catch invoice number blocks that sit below the header.
# IMAGE_OCR_TOP_FRACTION=0.40

# If your network blocks remote tessdata downloads, run scripts/download-eng-tessdata.*
# and keep TESSERACT_REMOTE_LANG_PATH unset (or set it to "" to force local-only).
# TESSERACT_REMOTE_LANG_PATH=
